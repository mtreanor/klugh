# Stress scenario — 100 rules, 1–5 predicates each.
# Groups:
#   A — social baseline        B — negation operators     C — history
#   D — temporal chains        E — numeric tiers/compares F — counts
#   G — private stores         H — derived consumers      I — sensors
#   J — importance/partial     K — boolean cascade        L — mixed/edge
#
# The K group is deliberately listed in REVERSE dependency order (K3 before
# K2 before K1) so a single applyOnce pass cannot complete the cascade —
# fixpoint apply() must take multiple passes.
#
# Rules D3, D5, and L1 are designed never to fire; the harness asserts that.

# ── A: social baseline ──────────────────────────────────────────────────────

rule "A1 — kindred craft"
  practices(?X, ?C)
  ^ practices(?Y, ?C)
  => goodwill(?X, ?Y) += 2

rule "A2 — innkeeper hospitality"
  worksAt(?X, tavern)
  ^ outsider(?Y)
  => goodwill(?X, ?Y) += 3

rule "A3 — defer to the elder"
  electedElder(?Y)
  ^ knows(?X, ?Y)
  => goodwill(?X, ?Y) += 1

rule "A4 — owner's pride"
  owns(?X, ?I)
  => prosperity(?X) += 1

rule "A5 — covetous itch"
  covets(?X, ?I)
  ^ owns(?Y, ?I)
  => tension(?X, ?Y) += 2

rule "A6 — few acquaintances, thin roots"
  |knows(?X, _)| < 3
  => prosperity(?X) -= 1

rule "A7 — provision draws the needy"
  hasNeed(?X, ?N)
  ^ canProvide(?Y, ?N)
  => goodwill(?X, ?Y) += 4

rule "A8 — unmet need unsettles"
  hasNeed(?X, _)
  ^ knows(?X, ?Y)
  => tension(?X, ?Y) += 0.5

# ── B: negation operators ───────────────────────────────────────────────────

rule "B1 — no feud, no fear"
  knows(?X, ?Y)
  ^ not feuding(?X, ?Y)
  => goodwill(?X, ?Y) += 1

rule "B2 — respect the recluse"
  -wantsVisitors(?Y)
  ^ knows(?X, ?Y)
  => tension(?X, ?Y) += 1

rule "B3 — open door"
  outsider(?X)
  ^ knows(?X, ?Y)
  ^ not -wantsVisitors(?Y)
  => goodwill(?X, ?Y) += 1

rule "B4 — no feud rumored"
  knows(?X, ?Y)
  ^ ~feuding(?X, ?Y)
  => goodwill(?X, ?Y) += 0.5

rule "B5 — quietly unwelcoming"
  not wantsVisitors(?Y)
  ^ knows(?X, ?Y)
  => tension(?X, ?Y) += 0.5

rule "B6 — never burned"
  knows(?X, ?Y)
  ^ not betrayed(?Y, ?X)
  => goodwill(?X, ?Y) += 0.5

rule "B7 — no grudge nursed"
  knows(?X, ?Y)
  ^ not ?X.grudgeAgainst(?X, ?Y)
  => goodwill(?X, ?Y) += 0.5

rule "B8 — grudge expressly dismissed"
  knows(?X, ?Y)
  ^ -?X.grudgeAgainst(?X, ?Y)
  => goodwill(?X, ?Y) += 5

# ── C: history ──────────────────────────────────────────────────────────────

rule "C1 — remembered betrayal"
  betrayed(?X, ?Y) [history]
  ^ knows(?X, ?Y)
  => tension(?Y, ?X) += 4

rule "C2 — fresh gratitude"
  helped(?X, ?Y) [history: 3]
  => goodwill(?Y, ?X) += 5

rule "C3 — kindness is never forgotten"
  helped(?X, ?Y) [history]
  => goodwill(?Y, ?X) += 1

rule "C4 — door once open, now barred"
  wantsVisitors(?X) [history]
  ^ -wantsVisitors(?X)
  ^ knows(?Y, ?X)
  => tension(?Y, ?X) += 1

rule "C5 — ancient acquaintance"
  knows(?X, ?Y) [at: -25]
  ^ betrayed(?X, ?Y) [history]
  => tension(?Y, ?X) += 2

rule "C6 — helping warmed the helper"
  helped(?X, ?Y) [history]
  ^ knows(?X, ?Y)
  => goodwill(?X, ?Y) += 0.5

rule "C7 — devotion remembered, now cooled"
  trust.devoted(?X, ?Y) [history]
  ^ trust(?X, ?Y) < 80
  => tension(?X, ?Y) += 1

rule "C8 — recent help spreads cheer"
  helped(?X, ?Y) [history: 5]
  => goodwill(?X, ?Y) += 2

rule "C9 — betrayal within living memory"
  betrayed(?X, ?Y) [history: 25]
  => tension(?Y, ?X) += 3

rule "C10 — weighted reckoning"
  knows(?X, ?Y) [importance: 2]
  ^ betrayed(?X, ?Y) [history] [importance: 0.5]
  => goodwill(?X, ?Y) += 4

# ── D: temporal chains ──────────────────────────────────────────────────────

rule "D1 — apology stirs hope"
  betrayed(?X, ?Y) then apologized(?X, ?Y)
  => goodwill(?Y, ?X) += 3

rule "D2 — swift contrition"
  betrayed(?X, ?Y) then[6] apologized(?X, ?Y)
  => goodwill(?Y, ?X) += 2

rule "D3 — contrition come too late"
  betrayed(?X, ?Y) then[3] apologized(?X, ?Y)
  => tension(?Y, ?X) += 9

rule "D4 — the full repair"
  betrayed(?X, ?Y) then apologized(?X, ?Y) then forgave(?Y, ?X)
  => goodwill(?Y, ?X) += 6

rule "D5 — wounds reopened"
  apologized(?X, ?Y) then betrayed(?X, ?Y)
  => tension(?Y, ?X) += 9

rule "D6 — trading insults, open feud"
  insulted(?X, ?Y) then insulted(?Y, ?X)
  ^ feuding(?X, ?Y)
  => tension(?X, ?Y) += 5

rule "D7 — tit for tat, promptly"
  insulted(?X, ?Y) then[2] insulted(?Y, ?X)
  => tension(?X, ?Y) += 2

rule "D8 — gossip comes back around"
  gossipedAbout(?X, ?Y) then gossipedAbout(?Y, ?X)
  => tension(?X, ?Y) += 3

# ── E: numeric tiers and comparisons ────────────────────────────────────────

rule "E1 — devotion shows"
  trust.devoted(?X, ?Y)
  => goodwill(?X, ?Y) += 3

rule "E2 — naked distrust"
  trust.none(?X, ?Y)
  ^ knows(?X, ?Y)
  => tension(?X, ?Y) += 3

rule "E3 — basking in repute"
  reputation.admired(?Y)
  ^ knows(?X, ?Y)
  => goodwill(?X, ?Y) += 1

rule "E4 — wary of the disgraced"
  reputation.pariah(?Y)
  ^ knows(?X, ?Y)
  => tension(?X, ?Y) += 1

rule "E5 — deep trust comforts"
  trust(?X, ?Y) >= 80
  => goodwill(?X, ?Y) += 2

rule "E6 — contempt corrodes"
  trust(?X, ?Y) < 20
  ^ knows(?X, ?Y)
  => tension(?X, ?Y) += 2

rule "E7 — warm regard"
  trust.high(?X, ?Y)
  ^ knows(?X, ?Y)
  => goodwill(?X, ?Y) += 1

rule "E8 — perfectly average"
  reputation(?X) = 50
  ^ outsider(?X)
  => prosperity(?X) += 1

rule "E9 — the poor seek shelter"
  prosperity.poor(?X)
  ^ canProvide(?Y, "shelter")
  ^ knows(?X, ?Y)
  => goodwill(?X, ?Y) += 2

rule "E10 — desperation breeds friction"
  prosperity(?X) <= 10
  ^ knows(?X, ?Y)
  => tension(?X, ?Y) += 1

# ── F: counts ───────────────────────────────────────────────────────────────

rule "F1 — sympathy for the talked-about"
  |gossipedAbout(_, ?Y)| >= 2
  ^ knows(?X, ?Y)
  => goodwill(?X, ?Y) += 2

rule "F2 — the well-connected prosper"
  |knows(?X, _)| >= 5
  => prosperity(?X) += 2

rule "F3 — quiet benefactor"
  |helped(?X, _)| >= 3
  => reputation(?X) += 2

rule "F4 — craft fellowship"
  practices(?X, ?C)
  ^ |practices(_, ?C)| >= 2
  => prosperity(?X) += 1

rule "F5 — singular treasure"
  |owns(?X, _)| = 1
  => prosperity(?X) += 1

rule "F6 — feuds weigh on all"
  |feuding(?X, _)| > 0
  ^ knows(?X, ?Y)
  => tension(?X, ?Y) += 0.5

rule "F7 — devotion steadies the heart"
  |trust.devoted(?X, _)| >= 1
  => prosperity(?X) += 1

rule "F8 — crowded quarters"
  livesAt(?X, ?P)
  ^ |livesAt(_, ?P)| >= 3
  => prosperity(?X) -= 1

# ── G: private stores ───────────────────────────────────────────────────────

rule "G1 — suspicion breeds distance"
  ?X.suspects(?X, ?Y)
  ^ knows(?X, ?Y)
  => tension(?X, ?Y) += 3

rule "G2 — petra's restless doubts"
  petra.suspects(petra, ?Y)
  ^ knows(petra, ?Y)
  => tension(petra, ?Y) += 1

rule "G3 — doubts expressly dismissed"
  -?X.suspects(?X, ?Y)
  ^ knows(?X, ?Y)
  => goodwill(?X, ?Y) += 2

rule "G4 — innocent until suspected"
  knows(?X, ?Y)
  ^ ~?X.suspects(?X, ?Y)
  => goodwill(?X, ?Y) += 1

rule "G5 — doubt never voiced"
  knows(?X, ?Y)
  ^ not -?X.suspects(?X, ?Y)
  => goodwill(?X, ?Y) += 0.5

rule "G6 — betrayal plants suspicion"
  betrayed(?X, ?Y) [history]
  => ?Y.suspects(?Y, ?X) [strength: 0.6]

rule "G7 — newcomers admire the locals"
  outsider(?Y)
  ^ knows(?X, ?Y)
  => ?Y.admires(?Y, ?X)

rule "G8 — admiration builds trust"
  ?X.admires(?X, ?Y)
  => ?X.trust(?X, ?Y) += 5

rule "G9 — mara's private devotion"
  mara.trust.devoted(mara, ?Y)
  => goodwill(mara, ?Y) += 2

rule "G10 — healed rift earns private regard"
  healedRift(?X, ?Y)
  => ?Y.admires(?Y, ?X) [strength: 0.8]

# ── H: derived consumers ────────────────────────────────────────────────────

rule "H1 — allies at ease"
  closeAllies(?X, ?Y)
  => goodwill(?X, ?Y) += 4

rule "H2 — rivalry simmers"
  rivals(?X, ?Y)
  ^ knows(?X, ?Y)
  => tension(?X, ?Y) += 3

rule "H3 — market rivalry sharpens"
  marketRival(?X, ?Y)
  => tension(?X, ?Y) += 2

rule "H4 — old wounds fester"
  oldWound(?X, ?Y)
  ^ knows(?X, ?Y)
  => tension(?X, ?Y) += 5

rule "H5 — rift healed, warmth returns"
  healedRift(?X, ?Y)
  => goodwill(?Y, ?X) += 5

rule "H6 — pity the gossiped newcomer"
  whisperTarget(?Y)
  ^ knows(?X, ?Y)
  ^ outsider(?Y)
  => goodwill(?X, ?Y) += 1

rule "H7 — consolation forges bonds"
  canConsole(?X, ?Y)
  ^ knows(?Y, ?X)
  => goodwill(?Y, ?X) += 2

rule "H8 — private enmity leaks"
  privateEnemy(?X, ?Y)
  ^ knows(?X, ?Y)
  => tension(?X, ?Y) += 4

rule "H9 — confide in the trusted"
  ?X.trustedConfidant(?X, ?Y)
  => goodwill(?X, ?Y) += 3

rule "H10 — blood is blood"
  kinOf(?X, ?Y)
  ^ knows(?X, ?Y)
  => goodwill(?X, ?Y) += 2

rule "H11 — the pillar steadies all"
  communityPillar(?Y)
  ^ knows(?X, ?Y)
  => goodwill(?X, ?Y) += 2

rule "H12 — mentor's shadow"
  mentorFigure(?X, ?Y)
  ^ knows(?X, ?Y)
  => goodwill(?Y, ?X) += 2

# ── I: sensors ──────────────────────────────────────────────────────────────

rule "I1 — pleasant company"
  near(?X, ?Y)
  ^ knows(?X, ?Y)
  => goodwill(?X, ?Y) += 1

rule "I2 — enemies in close quarters"
  near(?X, ?Y)
  ^ feuding(?X, ?Y)
  => tension(?X, ?Y) += 4

rule "I3 — a friend within reach"
  companionAtHand(?X, ?Y)
  => goodwill(?X, ?Y) += 1

rule "I4 — short walk to work"
  distanceTo.close(?X, ?P)
  ^ worksAt(?X, ?P)
  => prosperity(?X) += 1

rule "I5 — the long road wearies"
  distanceTo(?X, ?P) >= 10
  ^ worksAt(?X, ?P)
  => prosperity(?X) -= 1

rule "I6 — near enough to call on"
  distanceTo.walkable(?X, ?P)
  ^ livesAt(?Y, ?P)
  ^ knows(?X, ?Y)
  => goodwill(?X, ?Y) += 0.5

# ── J: importance and partial truth ─────────────────────────────────────────

rule "J1 — a friend proven and kept"
  knows(?X, ?Y) [importance: 2]
  ^ closeAllies(?X, ?Y)
  ^ helped(?X, ?Y) [history]
  => goodwill(?X, ?Y) += 4

rule "J2 — wanderer's burden"
  outsider(?X) [importance: 3]
  => prosperity(?X) -= 1

rule "J3 — trust outweighs acquaintance"
  trust(?X, ?Y) >= 60 [importance: 0.5]
  ^ knows(?X, ?Y) [importance: 2]
  => goodwill(?X, ?Y) += 2.5

rule "J4 — the benefit of the doubt"
  knows(?X, ?Y) [importance: 1.5]
  ^ trust(?X, ?Y) >= 95 [importance: 0.5]
  => goodwill(?X, ?Y) += 1

# ── K: boolean cascade (reverse dependency order — see header) ──────────────

rule "K3 — a seat at the chapel"
  electedElder(?X)
  => invitedTo(?X, chapel)

rule "K4 — the elder soothes quarrels"
  electedElder(?Z)
  ^ insulted(?X, ?Y)
  => not feuding(?X, ?Y)

rule "K6 — the elder shelters the respect-starved"
  electedElder(?X)
  ^ hasNeed(?Y, "respect")
  => helped(?X, ?Y)

rule "K7 — forgiveness flows back"
  healedRift(?X, ?Y)
  => forgave(?X, ?Y)

rule "K8 — the elder greets the stranger"
  electedElder(?X)
  ^ outsider(?Y)
  => knows(?X, ?Y)

rule "K2 — the vote is called"
  nominatedElder(?X)
  ^ communityPillar(?X)
  => electedElder(?X)

rule "K1 — devotion earns nomination"
  |trust.devoted(_, ?X)| >= 1
  ^ reputation(?X) >= 75
  => nominatedElder(?X)

# ── L: mixed and edge cases ─────────────────────────────────────────────────

rule "L1 — unbound negation never fires"
  not feuding(?Q, ?R)
  => tension(?Q, ?R) += 99

rule "L2 — friend of a friend, a stranger still"
  knows(?X, ?Y)
  ^ knows(?Y, ?Z)
  ^ not knows(?X, ?Z)
  => tension(?X, ?Z) += 0.1

rule "L3 — market hustle"
  worksAt(?X, market)
  ^ outsider(?X)
  => prosperity(?X) += 1

rule "L4 — old betrayals make new gossip"
  betrayed(?X, ?Y) [history: 25]
  ^ knows(?Z, ?X)
  => gossipedAbout(?Z, ?X) [strength: 0.6]

rule "L5 — the office burnishes"
  electedElder(?X)
  => reputation(?X) = 90

rule "L6 — gossip erodes trust"
  gossipedAbout(?X, ?Y)
  ^ knows(?Y, ?X)
  => trust(?Y, ?X) -= 2

rule "L7 — a kindness reopens the door"
  helped(?Y, ?X) [history: 2]
  => not -wantsVisitors(?X)

rule "L8 — the uninvolved drift"
  |helped(?X, _)| < 1
  ^ knows(?X, ?Y)
  => goodwill(?X, ?Y) += 0.5

rule "L9 — guests bring custom"
  invitedTo(?X, ?P)
  ^ worksAt(?Y, ?P)
  => goodwill(?Y, ?X) += 1
