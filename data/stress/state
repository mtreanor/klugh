# Stress scenario — a village of ten with thirty ticks of history.
# Exercises: backdating, strength, assert-then-retract, explicit disbelief,
# symmetric facts, single-valued attributes, numeric initialization, private
# stores with all three contradiction policies.

world
  # ── acquaintance web (knows is symmetric — one direction declared) ──
  knows(mara, oren)
  knows(mara, petra)
  knows(mara, talia)
  knows(mara, una)
  knows(mara, yara)
  knows(mara, zeke)
  knows(oren, silas) [tick: -31]
  knows(oren, petra)
  knows(oren, wren)
  knows(petra, una)
  knows(petra, wren)
  knows(petra, yara)
  knows(silas, viggo)
  knows(silas, yara)
  knows(talia, una)
  knows(talia, yara)
  knows(viggo, wren)
  knows(una, zeke)
  knows(yara, una)

  # ── deep history (negative ticks = before the simulation started) ──
  betrayed(oren, silas) [tick: -30]
  betrayed(oren, mara) [tick: -20] [strength: 0.9]
  apologized(oren, mara) [tick: -15]
  forgave(mara, oren) [tick: -10]
  helped(mara, talia) [tick: -12]
  helped(talia, mara) [tick: -9]
  helped(mara, una) [tick: -2]
  helped(mara, zeke) [tick: -1]
  helped(yara, silas) [tick: -1]
  insulted(wren, viggo) [tick: -6]
  insulted(viggo, wren) [tick: -5]
  gossipedAbout(petra, una) [tick: -4]
  gossipedAbout(wren, una) [tick: -3]
  gossipedAbout(petra, zeke) [tick: -2]

  # silas once welcomed visitors, no longer does, and has said so:
  # historically true, currently retracted, with explicit disbelief on record.
  wantsVisitors(silas) [tick: -8]
  not wantsVisitors(silas)
  -wantsVisitors(silas)

  # ── single-valued attribute: each agent holds at most one mood ──
  # feels is single-valued on its value arg (key = agent). zeke's mood was set
  # anxious, then updated to hopeful: the positive supersedes any prior value at
  # the key, so only hopeful is active — anxious survives in history.
  feels(zeke, anxious)
  feels(zeke, hopeful)
  feels(mara, content)
  # una has no settled mood — two moods ruled out by elimination. Negated
  # asserts do not own the slot, so both disbeliefs accumulate until a positive
  # value sweeps them.
  -feels(una, anxious)
  -feels(una, grieving)

  # ── current relations ──
  feuding(viggo, wren)

  livesAt(mara, tavern)
  livesAt(petra, tavern)
  livesAt(una, tavern)
  livesAt(oren, market)
  livesAt(wren, market)
  livesAt(zeke, market)
  livesAt(silas, mill)
  livesAt(viggo, mill)
  livesAt(talia, chapel)
  livesAt(yara, chapel)

