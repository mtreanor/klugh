rule "kindness warms friendship"
  helped(?X, ?Y)
  => friendship(?Y, ?X) += 5

rule "forgiveness follows demonstrated change"
  hadConflict(?Y, ?SELF) then helped(?SELF, ?Y)
  ^ |helped(?SELF, _)| >= 2
  ^ not trusts(?Y, ?SELF)
  ^ friendship.cold(?Y, ?SELF)
  ^ readyToForgive(?Y, ?SELF)
  => friendship(?Y, ?SELF) += 8
