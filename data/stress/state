# ── private stores ──

private mara
  admires(mara, talia)
  admires(mara, yara)
  suspects(mara, petra) [strength: 0.4]
  trust(mara, talia) = 81

# petra's store allows contradictions: she both suspects oren and
# disbelieves her own suspicion.
private petra
  suspects(petra, oren) [strength: 0.7]
  -suspects(petra, oren) [strength: 0.4]
  grudgeAgainst(petra, wren)

# silas's store blocks contradictions: the disbelief below is silently
# ignored because the positive grudge is already present.
private silas
  grudgeAgainst(silas, oren)
  -grudgeAgainst(silas, oren)
  suspects(silas, oren) [strength: 0.9]

private viggo
  grudgeAgainst(viggo, wren)

private wren
  -grudgeAgainst(wren, viggo)
